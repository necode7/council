{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "sandbox": {
        "network": {
            "allowedDomains": [
                "openrouter.ai"
            ]
        }
    },
    "hooks": {
        "SessionStart": [
            {
                "matcher": "",
                "hooks": [
                    {
                        "type": "command",
                        "command": "python3 -c 'import httpx, markdown2, weasyprint' 2>/dev/null || pip install -q httpx markdown2 weasyprint >/dev/null 2>&1 || true",
                        "timeout": 120
                    }
                ]
            }
        ]
    }
}
